#! /usr/bin/env bash

alias macvim='open -a MacVim '
alias gvim=macvim
alias inkscape='open -a inkscape'
alias gimp='open -a gimp'

alias word='open -a "Microsoft Word"'
alias excel='open -a "Microsoft Excel"'
alias illustrator='open -a "Adobe Illustrator"'
alias Rstudio='open -a "Rstudio"'

# sorted by name
alias l='ls -Galh'

# sorted by time
alias ll='ls -Galhtr'

# sorted by size
alias lS='ls -GalhtSr'

alias oepn='open'
