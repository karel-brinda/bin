# cd

alias cd-='cd -'
alias cd..='cd ..'
alias cd...='cd ../..'
alias cd....='cd ../../..'
alias cd.....='cd ../../../..'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'

alias cg='cd ~/github'
alias cgm='cd ~/github/my'

# git

alias ga='git add'
alias gb='git branch'
alias gs='git status'
alias gt='git commit'
alias gf='git diff --cached'
alias gpull='git pull --rebase'
alias gpush='git push'
alias g{='git stash -u'
alias g}='git stash pop'
alias gindex-='git update-index --assume-unchanged'
alias gindex+='git update-index --no-assume-unchanged'
alias gm='git mv'
alias gcl='git clean -fxd .'

# makes

alias cm='cmake . && clear && make -j 4'
alias sm='snakemake -p --cores'
