# cd

alias cd-='cd -'
alias cd..='cd ..'
alias cd...='cd ../..'
alias cd....='cd ../../..'
alias cd.....='cd ../../../..'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'

alias cg='cd ~/github'
alias cdd='cd ~/Desktop'
alias cdx='cd ~/Dropbox'
alias cdp='cd ~/phd-thesis'
alias cgm='cd ~/github/my'

# misc

alias p='pwd'
alias t='touch'
alias sa='source activate'
alias sd='source deactivate'

alias ff='find . -type f'
alias fd='find . -type d'

alias grep='grep --color=auto'
alias ffgrep='c && ff | xargs grep --color'

alias c='clear'

# git

alias gur='_git_update_repos'

alias g='git'

alias ga='git add'
alias gb='git branch'
alias gc='git checkout'
alias gba='git branch --all'
alias gs='git status'
alias gt='git commit'
alias gf='git diff --cached'
alias gpull='git pull --rebase'
alias gpush='git push'
alias g{='git stash -u'
alias g}='git stash pop'
alias gindex-='git update-index --assume-unchanged'
alias gindex+='git update-index --no-assume-unchanged'
alias gm='git mv'
alias gcl='git clean -fxd .'
alias gl='git log'

# makes

alias m='make VERBOSE=1'
alias cm='cmake . && clear && make -j 4'
alias sm='snakemake -p --cores'

# pdf

alias pdf_merge='pdfunite'
