# open the first / last directory/file
for i in $(seq 5);
do
	alias of$i='open "$(ls | mm '"$i"')"'
done
alias of='of1'

for i in $(seq 5);
do
	alias ol$i='open "$(ls | mm -'"$i"')"'
done
alias ol='ol1'

# open in a tmp dir
function ott {
    (
    p=$(pwd)
    t=$(date +%Y%m%d%H%M%S)
    mkdir "/tmp/$t"
    cd "/tmp/$t"
    cp "$p/$1" .
    open "$1"
    )
}

