########
# DASH #
########

# C++
function D.c {
    q=$(echo "$@" | perl -pe 's/ /%20/g')
    open "dash://cpp:$q"
}

# C
function D.cc {
    q=$(echo "$@" | perl -pe 's/ /%20/g')
    open "dash://c:$q"
}

# Python 3
function D.p {
    q=$(echo "$@" | perl -pe 's/ /%20/g')
    open "dash://python3:$q"
}

# Man pages
function D.m {
    q=$(echo "$@" | perl -pe 's/ /%20/g')
    open "dash://manpages:$q"
}

# Make
function D.mk {
    q=$(echo "$@" | perl -pe 's/ /%20/g')
    open "dash://make:$q"
}

