# cd

alias cd-='cd -'
alias cd..='cd ..'
alias cd...='cd ../..'
alias cd....='cd ../../..'
alias cd.....='cd ../../../..'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias b='cd -'

alias cg='cd ~/github'
alias cgb='cd ~/github/my/bin'
alias cgm='cd ~/github/my'
alias cgp='cd ~/github/my/projects'

alias cdb='cd ~/bin'
alias cde='cd ~/Desktop'
alias cdr='cd ~/github/my/rase'
alias cdd='cd ~/downloads || cd ~/Downloads'
alias cdx='cd ~/Dropbox'
alias cdg='cd ~/*Google*/'
alias ct='cd /tmp'
alias ctt='t=`date +%Y%m%d%H%M%S` && mkdir /tmp/$t && cd /tmp/$t'

alias md='mkdir'

mcd () {
	mkdir -p $1
	cd $1
}

#
alias sa='source activate'
alias sd='source deactivate'
alias sl='conda info --envs'

# misc

alias psk='ps aux | grep "^$USER"'
alias u='_update_all'
alias perlsed='perl -pe'
alias cpa='cp -av'
alias e='subl'
alias e.='subl .'
alias edit='subl'
alias o='open'
alias o.='open .'
alias p='pwd'
alias t='touch'
alias dfh='df -h'
alias dush='du -sh'
alias briss='java -jar ~/bin/programs/briss-0.9/briss-0.9.jar'
alias exif_delete_metadata='exiftool -all=""'

alias r='echo $?'

alias grep='grep --color=auto'
alias egrep='egrep --color=auto'
alias grepi='grep --color=auto -i'
#alias ffgrep='c && find . -type f -exec xargs grep --color {} \;'

alias c='clear'

alias phd='open http://brinda.cz/publications/brinda_phd.pdf'

# git

alias gur='git_update_repos'

if hash hub 2>/dev/null;
then
	alias git=hub
else
	alias git=git
fi

alias g='git'

alias ga='git add'
alias ga.='git add .'
alias gb='git branch'
alias gc='git checkout'
alias gc*='git checkout "*"'
alias gba='git branch --all'
alias gs='git status'
alias gs.='git status .'
alias gt='git commit'
alias gta='git commit --amend'
alias gf='git diff --cached'
alias gpull='git pull --rebase --all'
alias gpush='git push'
alias g{='git stash -u'
alias g}='git stash pop'
alias gindex-='git update-index --assume-unchanged'
alias gindex+='git update-index --no-assume-unchanged'
alias gm='git merge'
alias gcl='git clean -fxd'
alias gl='git log'
alias gh='git history'

alias piu='pip install --upgrade'
alias piu.='pip install --upgrade .'


# samtools

alias sv='samtools view'


# makes

alias m='make V=1'
alias mj='make V=1 -j'
alias mcl='make clean'
alias cm='cmake . && clear && make -j 4'
alias sm='snakemake -p'
alias smj='snakemake -p --cores 4242'

# pdf

alias pdf_merge='pdfunite'
