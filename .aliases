#! /usr/bin/env bash

#######################
# AUXILIARY FUNCTIONS #
#######################

NO_DOT_EXP=5

# e.g.. _strpow 10 "hello"
_strpow () {
	local i
	for i in $(seq $1);
	do
		echo -n "$2"
	done
}

# to speed-up loading, precompute dot strings
_dot_arrays () {
	local j
	for j in $(seq $NO_DOT_EXP);
	do
		local i=$(( $j + 1 ))
		DOTS1[$j]=$(_strpow $i ".")
		DOTS2[$j]=$(_strpow $j "../")
	done
}

_dot_arrays $NO_DOT_EXP

# e.g., _dotcmd cd: cd. = cd ., cd.. = cd ..
_dotcmd () {
	cmd="$1"
	local j
	alias "$cmd."="$cmd ."
	for j in $(seq $NO_DOT_EXP);
	do
		dotcmd="${cmd}${DOTS1[$j]}"
		expdotcmd="$cmd ${DOTS2[$j]}"
		alias "$dotcmd"="$expdotcmd"
	done
}

####################
# CHANGE DIRECTORY #
####################

alias b='cd -'
alias cd-='cd -'

# cd..='cd ..', etc.
_dotcmd cd

alias ..='cd..'
alias ...='cd...'
alias ....='cd....'
alias .....='cd.....'

alias cf='cd `ls -d */ | head -n 1`'
alias cl='cd `ls -d */ | tail -n 1`'

alias cdb='cd ~/bin'
alias cdd='cd ~/downloads || cd ~/Downloads'
alias cdx='cd ~/Dropbox'
alias cdg='cd ~/*Google*/'
alias cdo='cd ~/OneDrive/'
alias cde='cd ~/Desktop'

alias cg='cd ~/github'
alias cgc='cd ~/github/c2-d2'
alias cgb='cd ~/github/my/bin'
alias cgm='cd ~/github/my'
alias cgp='cd ~/github/my/projects'
alias cgpb='cd ~/github/my/projects/bin'
alias cgpp='cd ~/github/my/prophyle'
alias cgr='cd ~/github/my/rase*'
alias cgc='cd ~/github/c2-d2'

alias ct='cd /tmp'
alias ctt='t=`date +%Y%m%d%H%M%S` && mkdir /tmp/$t && cd /tmp/$t'

############
# CALENDAR #
############

# see https://github.com/insanum/gcalcli

alias cal='open https://calendar.google.com/calendar/render#main_7'
alias calm='gcalcli calm -w 15 --monday'
alias calw='gcalcli calw -w 15 --monday'
alias cald='gcalcli agenda -w 15 --monday `gdate "+%Y-%m-%d"` `gdate --date="tomorrow" "+%Y-%m-%d"`'


############
# MAKE DIR #
############

alias md='mkdir -p'
alias rd='rmdir'

mcd () {
	mkdir -p $1 && cd $1
}

alias cdm='mcd'


###############
# HEAD & TAIL #
###############

alias hh='head'
for i in $(seq 20); do
	alias hh$i="head -n $i"
done

alias tt='tail'
for i in $(seq 20); do
	alias tt$i="tail -n $i"
done

##################
# CONDA & PYTHON #
##################

alias sa='source activate'
alias sd='source deactivate'
alias sl='conda info --envs'

alias piu='pip install --upgrade'
_dotcmd piu

alias pu='pip uninstall'
_dotcmd pu


########
# EDIT #
########

# Vim

alias vl='vim -u NONE'

_dotcmd v
_dotcmd vv
_dotcmd vim

# Sublime
alias e='subl'
_dotcmd e
alias en='subl -n'
_dotcmd en

# Charm
alias charm='open -a /Applications/PyCharm\ CE.app'
_dotcmd charm


########
# OPEN #
########

alias o='open'
_dotcmd o

alias of='open "`ls | head -n 1`"'
alias ol='open "`ls | tail -n 1`"'


###############
# FIND & GREP #
###############

alias f='find'
alias f.='find .'
_dotcmd f


alias gg='grep --color=auto'
alias grep='grep --color=auto'
alias egrep='egrep --color=auto'
alias grepi='grep --color=auto -i'


#########
# SHELL #
#########

