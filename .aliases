####################
# CHANGE DIRECTORY #
####################

alias b='cd -'
alias cd-='cd -'
alias cd..='cd ..'

alias cd...='cd ../..'
alias cd....='cd ../../..'
alias cd.....='cd ../../../..'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'

alias cg='cd ~/github'
alias cgc='cd ~/github/c2-d2'
alias cgb='cd ~/github/my/bin'
alias cgm='cd ~/github/my'
alias cgp='cd ~/github/my/projects'
alias cgpp='cd ~/github/my/prophyle'
alias cdb='cd ~/bin'
alias cde='cd ~/Desktop'
alias cdr='cd ~/github/my/rase'
alias cdd='cd ~/downloads || cd ~/Downloads'
alias cdx='cd ~/Dropbox'
alias cdg='cd ~/*Google*/'
alias ct='cd /tmp'
alias ctt='t=`date +%Y%m%d%H%M%S` && mkdir /tmp/$t && cd /tmp/$t'


############
# MAKE DIR #
############

alias md='mkdir -p'

mcd () {
	mkdir -p $1
	cd $1
}


##################
# CONDA & PYTHON #
##################

alias sa='source activate'
alias sd='source deactivate'
alias sl='conda info --envs'

alias piu='pip install --upgrade'
alias piu.='pip install --upgrade .'


###############
# EDIT & OPEN #
###############

alias e='subl'
alias en='subl -n'
alias e.='subl .'
alias en.='subl -n .'
alias edit='subl'
alias o='open'
alias o.='open .'


###############
# FIND & GREP #
###############

alias f='find'
alias f.='find .'

alias grep='grep --color=auto'
alias egrep='egrep --color=auto'
alias grepi='grep --color=auto -i'


#########
# SHELL #
#########

alias r='echo $?'
alias psk='ps aux | grep "^$USER"'
alias cpa='cp -av'
alias p='pwd'
alias t='touch'
alias dfh='df -h'
alias dush='du -sh'
alias wcl='wc -l'


##################
# BIOINFORMATICS #
##################

alias sv='samtools view'
alias phd='open http://brinda.cz/publications/brinda_phd.pdf'


####################
# MAKE & SNAKEMAKE #
####################

alias m='make V=1'
alias mj='make V=1 -j'
alias mC='make -C'
alias mjC='make -j -C'
alias mcl='make clean'
alias cm='cmake . && clear && make -j 4'
alias sm='snakemake -p'
alias smj='snakemake -p --cores 4242'


#######
# PDF #
#######

alias pdf_merge='pdfunite'
alias briss='java -jar ~/bin/programs/briss-0.9/briss-0.9.jar'
alias exif_delete_metadata='exiftool -all=""'


########
# MISC #
########

alias ggdb='sudo gdb --args'
alias u='_update_all'
alias pe='perl -pe'
alias md2html='markdown_py'
