alias psk='ps aux | grep "^$USER"'
alias cpa='cp -av'
#alias h='hostname'
alias p='pwd'
alias t='touch'
alias lns='df -h'
alias dfh='df -h'
alias dush='du -sh'
alias wcl='wc -l'
alias tab="column -t -s '	'"
alias x='xargs'
alias x1='xargs -n 1'
alias psg="ps aux | grep -v grep | grep -i -e VSZ -e"


##################
# BIOINFORMATICS #
##################

alias sv='samtools view'
alias sfi='samtools faidx'
