# cd

alias cd-='cd -'
alias cd..='cd ..'
alias cd...='cd ../..'
alias cd....='cd ../../..'
alias cd.....='cd ../../../..'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias b='cd -'

alias cg='cd ~/github'
alias cgm='cd ~/github/my'
alias cgp='cd ~/github/my/projects'

alias cde='cd ~/Desktop'
alias cdd='cd ~/downloads || cd ~/Downloads'
alias cdx='cd ~/Dropbox'
alias cdg='cd ~/*Google*/'
alias cdp='cd ~/phd-thesis'

alias md='mkdir'

# misc

alias e='subl'
alias e.='subl .'
alias edit='subl'
alias o='open'
alias o.='open .'
alias p='pwd'
alias t='touch'
alias sa='source activate'
alias sd='source deactivate'

alias ff='find . -type f'
alias fd='find . -type d'

alias grep='grep --color=auto'
#alias ffgrep='c && find . -type f -exec xargs grep --color {} \;'

alias c='clear'

# git

alias gur='git_update_repos'

if hash hub 2>/dev/null;
then
	alias git=hub
else
	alias git=git
fi

alias g='git'

alias ga='git add'
alias gb='git branch'
alias gc='git checkout'
alias gba='git branch --all'
alias gs='git status'
alias gt='git commit'
alias gf='git diff --cached'
alias gpull='git pull --rebase --all'
alias gpush='git push'
alias g{='git stash -u'
alias g}='git stash pop'
alias gindex-='git update-index --assume-unchanged'
alias gindex+='git update-index --no-assume-unchanged'
alias gm='git mv'
alias gcl='git clean -fxd'
alias gl='git log'

# samtools

alias sv='samtools view'


# makes

alias m='make V=1'
alias mj='make V=1 -j'
alias cm='cmake . && clear && make -j 4'
alias sm='snakemake -p'
alias smj='snakemake -p --cores'

# pdf

alias pdf_merge='pdfunite'
